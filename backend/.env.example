# Express API Server port
PORT=5000

# Node execution environment (development or production)
NODE_ENV=development

# Google Cloud OAuth Client ID (from credentials panel)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Cloud OAuth Client Secret
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth callback redirection URL
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Gemini API Keys (comma-separated if using multiple keys for fallback, or just one key)
GEMINI_API_KEYS=your_first_gemini_api_key_here,your_second_gemini_api_key_here

# Supabase PostgreSQL Database connection string
DATABASE_URL=postgresql://postgres:your_password_here@db.your_project_id.supabase.co:5432/postgres

# Secret key used to sign session JSON Web Tokens (JWT)
JWT_SECRET=your_jwt_session_secret_key_here
